rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Sessions ─────────────────────────────────────────────────────────────
    // Any authenticated user (ESP32 anonymous auth or Flutter app) can
    // read and create sessions. The Cloud Function (admin SDK) can do anything.
    match /sessions/{sessionId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;

      // ── Exchanges (subcollection) ─────────────────────────────────────────
      // ESP32 creates exchanges (questions); Cloud Function writes answers.
      match /exchanges/{exchangeId} {
        allow read: if request.auth != null;

        // Device can create a new pending exchange
        allow create: if request.auth != null
                      && request.resource.data.keys().hasAll(['question', 'status', 'askedAt'])
                      && request.resource.data.status == 'pending';

        // Answers are written by Cloud Functions (admin SDK — bypasses rules)
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}

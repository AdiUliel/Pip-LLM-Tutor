rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // materials/{childId}/{filename} — homework uploads by the parent app.
    // Any authenticated user (parent app uses email/password; the ESP32
    // device uses anonymous auth and fetches the file URL via Firestore).
    // 5 MB cap mirrors AppConstants.maxUploadBytes.
    match /materials/{childId}/{file=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024;
    }
  }
}

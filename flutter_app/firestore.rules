rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // parents/{uid} — a parent can only read/write their own document.
    match /parents/{parentId} {
      allow read, write: if request.auth != null && request.auth.uid == parentId;
    }

    // children, materials — any authenticated user (parent app uses
    // email/password; the ESP32 device uses anonymous auth). Authorization
    // is enforced by the app (children.parentId == auth.uid is queried
    // client-side); tighten when device auth model is finalised.
    match /children/{childId} {
      allow read, write: if request.auth != null;
    }

    match /materials/{materialId} {
      allow read, write: if request.auth != null;
    }

    // sessions — written by the device, read by the parent app.
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null;

      match /questions/{questionId} {
        allow read, write: if request.auth != null;
      }
    }

    // deviceState — written by the device, read by the parent app.
    match /deviceState/{deviceId} {
      allow read, write: if request.auth != null;
    }
  }
}

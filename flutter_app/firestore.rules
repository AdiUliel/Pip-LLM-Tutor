rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function sessionDoc(sessionId) {
      return get(/databases/$(database)/documents/sessions/$(sessionId));
    }

    match /devices/{deviceId} {
      allow read, write: if signedIn() && request.auth.uid == deviceId;
    }

    match /deviceState/{deviceId} {
      allow read, write: if signedIn();
    }

    match /children/{childId} {
      allow read, write: if signedIn();
    }

    match /materials/{materialId} {
      allow read, write: if signedIn();
    }

    match /sessions/{sessionId} {
      allow read: if signedIn();
      allow create: if signedIn()
                    && request.resource.data.keys().hasAll(['childId', 'deviceId', 'subject', 'startedAt']);
      allow update: if signedIn();
      allow delete: if false;

      match /exchanges/{exchangeId} {
        allow read: if signedIn();
        allow create: if signedIn()
                      && request.resource.data.status == 'pending'
                      && (
                        request.resource.data.childAnswer is string ||
                        request.resource.data.childAnswerTranscript is string ||
                        request.resource.data.question is string
                      );
        allow update, delete: if false;
      }

      match /questions/{questionId} {
        allow read: if signedIn();
        allow create, update, delete: if false;
      }
    }
  }
}
